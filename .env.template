#PORT
PORT=<PORT>
TIMEZONE=<TIMEZONE>
NODE_ENV=development

#JWT
JWT_SECRET=<JWT_SECRET_MIN_16_CHARS>
JWT_EXPIRES_IN=1d

# IA (Claude)
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
IA_MODEL=claude-sonnet-4-6
IA_MAX_TOKENS=800
IA_TEMPERATURE=0.2
IA_PROMPT_CACHE_ENABLED=true
IA_SUMMARY_CACHE_TTL_SECONDS=1800
IA_SUMMARY_RATE_LIMIT_MAX=10
IA_SUMMARY_RATE_LIMIT_WINDOW_SECONDS=3600
IA_HYBRID_SUMMARY_ENABLED=true
IA_HYBRID_MAX_TOKENS=350
IA_WEEKLY_BATCH_ENABLED=true
IA_WEEKLY_BATCH_INTERVAL_SECONDS=86400

#FRONTEND
FRONTEND_URL=<FRONTEND_URL>

#NOTIFICATIONS (Power Automate webhook)
TEAMS_WEBHOOK_URL=<TEAMS_WEBHOOK_URL>

#DB Configuration
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
DATABASE_URL="postgresql://postgres:root@localhost:5432/siradb?schema=public"
